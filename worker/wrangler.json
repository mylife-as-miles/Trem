{
  "name": "trem-ai-worker",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-24",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "trem-ai-db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "trem-ai-assets"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "PROJECT_COORDINATOR",
        "class_name": "ProjectCoordinatorDO"
      }
    ]
  },
  "workflows": [
    {
      "name": "ingestion-workflow",
      "binding": "INGESTION_WORKFLOW",
      "class_name": "IngestionWorkflow"
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["ProjectCoordinatorDO"]
    }
  ]
}
